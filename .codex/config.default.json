{
  "profiles": {
    "admin": {
      "match": { "groups": ["minime"] },
      "features": ["packadmin"]
    },
    "sarah-lucas": {
      "match": { "contacts": ["sarah", "lucas"], "groups": ["banco_franklin", "filhos_franklin"] },
      "features": ["manualForward"],
      "allowedDestinations": ["whats_GPO_Banco_Franklin", "whats_GPO_FranklinHeaderSync", "self"],
      "allowedSources": ["franklin"]
    }
  },
  "features": {
    "packadmin": {
      "commands": [
        "dailyTasks",
        "mealLog",
        "sleepLog",
        "workoutLog",
        "screenLog",
        "gamingLog",
        "procrastLog",
