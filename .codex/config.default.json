      "commands": ["manualForward", "audioProcessing"]
    }
  },
  "flags": {
    "data": {
      "description": "Sobrescrever a data da métrica",
      "values": {
        "hoje": "today",
        "ontem": "yesterday",
        "anteontem": "day_before_yesterday",
        "amanha": "tomorrow",
        "amanhã": "tomorrow"
      },
      "range": {
        "value": "ate",
        "description": "Buscar entre data inicial e data final",
        "example": "-data:hoje até 15/05"
      },
      "dataref": {
        "description": "Usar coluna data.referencia em vez de data",
        "values": ["sim", "nao", "yes", "no", "true", "false"],
        "default": "nao"
      }
    },
    "force": {
      "description": "Forçar sobrescrita de métricas existentes",
      "values": ["force", "correcao", "correção"],
      "default": false
    }
  },
  "labels": {
